

{% extends 'pages/base.jinja' %}


{% block content %}

    <form method="post" action="/club" enctype="multipart/form-data">
        <label>
            Name
            <input name="name" type="text" required>
        </label>

        <label>
            Logo
            <input
                name="logo"
                type="file"
                accept="image/png, image/jpeg, image/gif, image/webp"
                required
            >
        </label>

        <button>Add Club</button>
    </form>

{% endblock %}

