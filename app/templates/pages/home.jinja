{#=====================================================
  Home page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block title %}

    Flask Demo

{% endblock %}


{% block content %}

    <h1>Notes</h1>

    <section class="notes">

        {% for note in notes %}

            <article class="note">

                <h3>
                    {{ note.title }}
                    {{ "📌" if note.pinned }}
                </h3>
                <p>{{ note.body }}</p>
                <p>{{ note.created | local | format }}</p>

            </article>

        {% else %}

            <p>None!</p>

        {% endfor %}

    </section>

{% endblock %}

